{
  "sections": [
    {
      "id": "top-wrapper",
      "component": "Wrapper",
      "props": {
        "tag": "header",
        "className": "bg-primary text-white p-4",
        "sections": [
          {
            "component": "Navigation",
            "props": {
              "logo": {
                "text": "Lifecycle Demo"
              },
              "menuItems": [
                {
                  "label": "Features",
                  "action": {
                    "type": "navigate",
                    "url": "#features"
                  }
                },
                {
                  "label": "About",
                  "action": {
                    "type": "navigate",
                    "url": "#about"
                  }
                }
              ]
            }
          }
        ]
      },
      "lifetime": {
        "onMount": [
          {
            "type": "log",
            "message": "Top wrapper mounted!"
          }
        ]
      }
    },
    {
      "id": "features",
      "component": "Hero",
      "props": {
        "title": "Nested Wrappers & LifeCycle",
        "subtitle": "Testing the new engine capabilities | Open console to see lifecycle logs",
        "backgroundImage": "https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&q=80&w=2000",
        "primaryButton": {
          "label": "Try it now",
          "onClick": {
            "type": "navigate",
            "url": "success"
          }
        }
      },
      "lifetime": {
        "beforeMount": {
          "type": "setState",
          "key": "isTesting",
          "value": true
        },
        "onMount": [
          {
            "type": "log",
            "message": "Hero section ready!"
          },
          {
            "type": "analytics",
            "event": "section_view",
            "properties": {
              "name": "hero"
            }
          },
          {
            "type": "post",
            "url": "https://api.example.com/submit",
            "onSuccess": {
              "type": "navigate",
              "url": "/thanks"
            },
            "onError": {
              "type": "log",
              "message": "Error"
            }
          }
        ]
      }
    },
    {
      "id": "about",
      "component": "Wrapper",
      "props": {
        "tag": "section",
        "className": "py-16 px-4 bg-white dark:bg-slate-900 border-t border-slate-100 dark:border-slate-800",
        "sections": [
          {
            "component": "Wrapper",
            "props": {
              "className": "max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8",
              "sections": [
                {
                  "component": "FeatureCard",
                  "props": {
                    "title": "Left Column Logic",
                    "subtitle": "Hooks",
                    "description": "This component tracks internal state and lifecycle events in the left container.",
                    "icon": "analytics",
                    "image": "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&q=80&w=800",
                    "className": "h-full"
                  }
                },
                {
                  "component": "FeatureCard",
                  "props": {
                    "title": "Right Column Logic",
                    "subtitle": "State",
                    "description": "Another nested wrapper demonstrating independent state isolation and event handling.",
                    "icon": "account_tree",
                    "image": "https://images.unsplash.com/photo-1516116216624-53e697fedbea?auto=format&fit=crop&q=80&w=800",
                    "className": "h-full"
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "id": "footer-wrapper",
      "component": "Wrapper",
      "props": {
        "tag": "footer",
        "className": "bg-secondary text-white p-8 text-center",
        "sections": [
          {
            "component": "Footer",
            "props": {
              "logo": { "text": "Lifecycle Demo" },
              "copyright": "© 2026 Lifecycle Demo",
              "links": [
                { "label": "Facebook", "href": "https://facebook.com" },
                { "label": "Twitter", "href": "https://twitter.com" }
              ]
            },
            "lifetime": {
              "onUnmount": {
                "type": "log",
                "message": "Footer area unmounted (goodbye!)"
              }
            }
          }
        ]
      }
    }
  ]
}
