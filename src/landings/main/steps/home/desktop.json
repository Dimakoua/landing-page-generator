                        }
                      },
                      {
                        "component": "FeatureCard",
                        "props": {
                          "className": "h-full",
                          "title": "E-Commerce Flow",
                          "subtitle": "Storefront",
                          "description": "End-to-end product funnel with cart management and checkout steps.",
                          "icon": "shopping_cart",
                          "image": "https://images.unsplash.com/photo-1472851294608-062f824d29cc?auto=format&fit=crop&q=80&w=800",
                          "primaryButton": {
                            "label": "View Demo",
                            "onClick": { "type": "navigate", "url": "/sample" }
                          }
                        }
                      }
                    ]
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "id": "footer",
      "component": "Footer",
      "props": {
        "logo": {
          "text": "Landing Page Factory"
        },
        "links": [
          { "label": "Repository", "url": "https://github.com" },
          { "label": "Documentation", "url": "https://github.com" },
          { "label": "Wizard", "url": "/wizard" }
        ]
      }
    }
  ]
